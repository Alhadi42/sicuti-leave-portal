# === SUPABASE SICUTI (Database utama SiCuti) ===
SUPABASE_PROJECT_ID="ociedycfgkqvcqwdxprt"
VITE_SUPABASE_PROJECT_ID="ociedycfgkqvcqwdxprt"

SUPABASE_URL="https://ociedycfgkqvcqwdxprt.supabase.co"
VITE_SUPABASE_URL="https://ociedycfgkqvcqwdxprt.supabase.co"

# Anon key — SATU-SATUNYA key yang boleh di frontend (RLS aktif)
VITE_SUPABASE_ANON_KEY="your_sicuti_anon_key"
VITE_SUPABASE_PUBLISHABLE_KEY="your_sicuti_anon_key"

# Service role — HANYA untuk Vercel API / Edge Functions (JANGAN prefix VITE_)
# Wajib diset di Vercel → Settings → Environment Variables:
SUPABASE_SERVICE_ROLE_KEY="your_sicuti_service_role_key"

# === SSO SIMPEL (Identity Provider) ===
VITE_SIMPEL_APP_URL="https://simpel.sipandai.site"
# Domain production SiCuti (untuk callback SSO — jangan samakan dengan SIMPEL)
VITE_SICUTI_APP_URL="https://cuti.sipandai.site"

# Server-only (Vercel Environment Variables — Production):
SIMPEL_URL="https://mauyygrbdopmpdpnwzra.supabase.co"
SIMPEL_ANON_KEY="your_simpel_anon_key"
SIMPEL_SERVICE_ROLE_KEY="your_simpel_service_role_key"
SSO_SHARED_SECRET="generate_random_64_char_secret_shared_with_simpel"

# === DEPRECATED — HAPUS dari production ===
# VITE_SUPABASE_SERVICE_ROLE_KEY  ← JANGAN gunakan di frontend
# VITE_SIMPEL_SERVICE_ROLE_KEY    ← JANGAN gunakan di frontend
# VITE_SIMPEL_URL                 ← pindah ke secret Edge Function

# === Application ===
VITE_APP_VERSION="1.0.0"
VITE_TEMPO=false

# === Google Drive Integration (untuk upload dokumen cuti) ===
# PENTING: Gunakan secret yang SAMA dengan simpel-lavotas!
# Copy dari Supabase simpel-lavotas → Edge Functions → Manage Secrets
# Lovable API key untuk connector gateway
LOVABLE_API_KEY="your_lovable_api_key"
# Google Drive API key (dari connector Lovable)
GOOGLE_DRIVE_API_KEY="your_google_drive_api_key"
